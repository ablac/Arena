ARENA_DB_HOST=arena-db
ARENA_DB_PORT=5432
ARENA_DB_HOST_PORT=5433
ARENA_DB_NAME=arena
ARENA_DB_USER=arena_user
ARENA_DB_PASSWORD=changeme_arena_2026
# Managed production deployments use a DDL-free runtime role above and an
# owner/migrator role only for release-time schema work. Keep false for the
# simple local single-role setup.
# ARENA_DB_MIGRATIONS_MANAGED=false
# In managed deployments these also pin the PostgreSQL container's bootstrap
# owner and healthcheck identity, preventing drift to the runtime app role.
# ARENA_DB_MIGRATOR_USER=arena_user
# Optional only when the migrator intentionally shares ARENA_DB_PASSWORD.
# ARENA_DB_MIGRATOR_PASSWORD=
ARENA_REDIS_HOST=arena-redis
ARENA_REDIS_PORT=6379
ARENA_REDIS_HOST_PORT=6380
ARENA_ADMIN_TOKEN=changeme_admin_token
ARENA_SECRET_KEY=changeme_secret_key

# Anonymous Get Started registration is server-generated and persisted in
# PostgreSQL. Redis limits each source IP per minute; PostgreSQL provides a
# durable hourly backstop. Registration fails closed if either dependency is
# unavailable.
# ARENA_RATE_LIMIT_REGISTER_RPM=10
# ARENA_RATE_LIMIT_REGISTER_PER_HOUR=500

# Anonymous spectator WebSocket handshakes use their own per-IP Redis bucket.
# The 60/minute default accommodates viewers behind a shared NAT while
# bounding upgrade churn; set 0 to disable this admission limit.
ARENA_WS_SPECTATOR_CONNECT_RATE_PER_MIN=60

# Forwarded client-IP headers are ignored unless the request arrives from one
# of these immediate reverse-proxy networks. Loopback proxies are trusted by
# default. For containers, use the smallest dedicated proxy CIDR visible to
# Arena; do not add public or general-purpose private networks.
# ARENA_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
# `CF-Connecting-IP` is ignored for ordinary trusted proxies. If the immediate
# peer is a Cloudflare-controlled tunnel/proxy that overwrites this header,
# list that peer in both variables. Never put a generic Caddy network here.
# ARENA_TRUSTED_CLOUDFLARE_PROXY_CIDRS=

# Optional admin OIDC. This is a separate, private admin application. OIDC is
# fail-closed unless at least one verified email is explicitly allowed.
# ARENA_OIDC_ENABLED=false
# ARENA_OIDC_ISSUER=https://idp.example/application/o/arena-admin/
# ARENA_OIDC_CLIENT_ID=arena-admin
# ARENA_OIDC_CLIENT_SECRET=
# ARENA_OIDC_REDIRECT_URI=https://arena.example/admin/callback
# ARENA_OIDC_ADMIN_EMAILS=owner@example.com,operator@example.com
# ARENA_OIDC_SESSION_TTL_HOURS=8

# Self-update sidecar (optional). The Admin Panel "Update to latest" button is
# only enabled when both of these are set and point at a running arena-updater
# sidecar (see docs/build-and-deploy.md). Bring the sidecar up with:
#   docker compose --profile updater up -d arena-server arena-updater
# ARENA_UPDATER_URL=http://arena-updater:8090/update
# ARENA_UPDATER_SHARED_SECRET=   # openssl rand -hex 32
# Optional: raises the GitHub tarball/compare rate limit. Arena is a public
# repo, so this is not required.
# ARENA_UPDATE_GITHUB_TOKEN=
# Repo/branch the "update to latest" check tracks (defaults shown).
# ARENA_UPDATE_REPO=ablac/Arena
# ARENA_UPDATE_BRANCH=main
# uid:gid the updater's post-sync ownership restore chowns code back to (used by
# the arena-updater service in docker-compose.yml, e.g. 1000:1001).
# DEPLOY_OWNER=

# Server-authoritative terrain movement pace for a balanced speed allocation.
# The 0.35 default is deliberately calmer than the previous 0.5 cells/tick;
# lower and higher speed stats, boosts, and projectile lead scale from it.
# ARENA_TERRAIN_MOVE_CELLS_PER_TICK=0.35

# Automatic weapon balance safety window (defaults shown). A weapon is only
# changed after the full round/sample/player thresholds are met and its 95%
# confidence interval clears the minimum practical effect.
# ARENA_WEAPON_AUTO_BALANCE_MIN_ROUNDS=6
# ARENA_WEAPON_AUTO_BALANCE_MIN_BOT_SAMPLES=18
# The built-in roster has two independently configured bots per weapon.
# ARENA_WEAPON_AUTO_BALANCE_MIN_DISTINCT_BOTS=2
# ARENA_WEAPON_AUTO_BALANCE_MIN_ACTIONS=5
# ARENA_WEAPON_AUTO_BALANCE_CONFIDENCE_Z=1.96
# ARENA_WEAPON_AUTO_BALANCE_MIN_EFFECT=0.05
# Noisy evidence is retained across rounds, then expires without reducing the
# next correction step if it remains inconclusive at this bounded window.
# ARENA_WEAPON_AUTO_BALANCE_MAX_EVIDENCE_ROUNDS=48
# Runtime scales are clamped to these validated safety rails.
# ARENA_WEAPON_AUTO_BALANCE_MIN_DAMAGE_SCALE=0.70
# ARENA_WEAPON_AUTO_BALANCE_MAX_DAMAGE_SCALE=1.40
# ARENA_WEAPON_AUTO_BALANCE_MIN_COOLDOWN_SCALE=0.75
# ARENA_WEAPON_AUTO_BALANCE_MAX_COOLDOWN_SCALE=1.35

# Kill-based Elo uses a matched transfer, and every rating path is bounded.
# Startup clamps legacy ratings inflated by the previous asymmetric formula.
# ARENA_ELO_MIN=100
# ARENA_ELO_MAX=3000

# Customer cosmetic accounts (optional). Use a dedicated public/customer OIDC
# client; never reuse the admin OIDC client. The ID token must include a
# non-empty email and email_verified=true.
# ARENA_CUSTOMER_OIDC_ENABLED=false
# ARENA_CUSTOMER_OIDC_ISSUER=https://idp.example/application/o/arena-customer/
# ARENA_CUSTOMER_OIDC_CLIENT_ID=arena-customer
# ARENA_CUSTOMER_OIDC_CLIENT_SECRET=
# ARENA_CUSTOMER_OIDC_REDIRECT_URI=https://arena.example/account/callback
# Session lifetime with sliding renewal: any signed-in request made after more
# than half the TTL has elapsed extends the session back out to a full TTL
# (both the server-side session and the browser cookie's MaxAge), so a
# visitor who returns at least once within any TTL-length window stays signed
# in indefinitely. Sessions are durable across a server restart (a small
# customer_sessions table backs the in-memory cache), so this alone is what
# makes "stay signed in" mean something beyond a single process's uptime.
# ARENA_CUSTOMER_OIDC_SESSION_TTL_HOURS=720
# ARENA_CUSTOMER_BOT_LINK_RPM=10
# ARENA_CUSTOMER_BOT_LINK_PER_HOUR=10
# Customer key mutations are fail-closed per IP in Redis and independently
# bounded per verified account in PostgreSQL, so rotating IPs cannot bypass them.
# ARENA_CUSTOMER_API_KEY_MUTATION_RPM=30
# ARENA_CUSTOMER_API_KEY_CREATE_PER_HOUR=10
# ARENA_CUSTOMER_API_KEY_REVOKE_PER_HOUR=20
# Inventory reads are limited per IP and per verified account before ownership
# synchronization, protecting the catalog-backed Dashboard query from scraping.
# ARENA_COSMETICS_ACCOUNT_READ_RPM=60

# Native passwordless customer registration (optional alternative to customer
# OIDC). Arena emails a 15-minute, single-use link, stores only its SHA-256
# digest in PostgreSQL, and verifies it with a same-origin Dashboard POST. The
# SMTP credential should be a send-only app password for the exact From mailbox.
# Redis is required for send rate limiting; link requests return 503 rather than
# send unbounded mail while Redis is unavailable.
# ARENA_CUSTOMER_EMAIL_AUTH_ENABLED=false
# ARENA_CUSTOMER_EMAIL_SIGN_IN_URL=https://arena.example/dashboard/
# ARENA_CUSTOMER_EMAIL_TOKEN_TTL_MINUTES=15
# ARENA_CUSTOMER_EMAIL_SEND_COOLDOWN_SECONDS=60
# ARENA_CUSTOMER_EMAIL_SEND_RPM=5
# Angel-serv Stalwart submission is tailnet-only at 100.71.171.28:465. Keep the
# certificate name separate from the private address; TLS verification remains
# enabled. Never use the public MTA listener on port 25.
# ARENA_SMTP_HOST=100.71.171.28
# ARENA_SMTP_PORT=465
# ARENA_SMTP_TLS_MODE=implicit
# ARENA_SMTP_TLS_SERVER_NAME=mail.angel-serv.com
# ARENA_SMTP_USERNAME=noreply@angel-serv.com
# ARENA_SMTP_PASSWORD=
# ARENA_SMTP_FROM=Arena <noreply@angel-serv.com>

# Developer lobby chat (optional, disabled by default). Reading is always
# public once enabled; posting requires a signed-in customer session (see the
# customer OIDC / native email auth blocks above), so enabling chat without
# either of those yields a read-only lobby. This env var only seeds the
# initial on/off state the first time Arena starts against a fresh database;
# after that, turn chat on or off any time from the admin panel's Chat
# Moderation tab -- no env var edit or restart needed.
# ARENA_CHAT_ENABLED=false
# ARENA_CHAT_MAX_CLIENTS=200
# ARENA_CHAT_HISTORY_SIZE=50
# ARENA_CHAT_MAX_BODY_LEN=280
# ARENA_CHAT_POSTS_PER_MIN=12
# Blocks posting while any bot linked to the poster's account is alive in an
# active round, so chat cannot be used to coordinate live bots (the spectator
# stream is delayed for the same reason).
# ARENA_CHAT_ALIVE_LOCK=true

# Cosmetic checkout (optional, disabled by default). Checkout fails closed unless
# either dedicated customer OIDC or native verified-email auth is complete and
# PostgreSQL and Redis are required. Checkout returns 503 while Redis cannot
# enforce its per-client quota. Prices and pack contents always come from
# Arena's server-side catalog; the browser never supplies an amount.
# ARENA_COSMETICS_CHECKOUT_ENABLED=false
# ARENA_COSMETICS_CHECKOUT_RPM=10
# Keep this API key and the Billing Portal return URL configured while
# subscription webhooks are still accepted, including a sales pause. Arena
# retrieves nonterminal subscriptions before changing access and keeps
# cancellation self-service available while new checkout is disabled.
# Restricted keys are supported when they can create/retrieve Checkout and
# Billing Portal sessions plus retrieve subscriptions. The publishable key is
# intentionally browser-visible; it must use the same test/live mode.
# ARENA_STRIPE_SECRET_KEY=rk_live_replace_me
# ARENA_STRIPE_PUBLISHABLE_KEY=pk_live_replace_me
# Comma-separated so a webhook signing secret can be rotated without downtime.
# ARENA_STRIPE_WEBHOOK_SECRETS=whsec_current,whsec_previous
# Hosted Checkout remains an explicit fallback. Embedded Checkout uses its own
# return URL for payment methods that temporarily leave the Arena dialog. Stripe
# replaces the literal placeholder with the Checkout Session ID.
# ARENA_STRIPE_SUCCESS_URL=https://YOUR_ARENA_HOST/dashboard/?tab=cosmetics&checkout=success&session_id={CHECKOUT_SESSION_ID}
# ARENA_STRIPE_CANCEL_URL=https://YOUR_ARENA_HOST/dashboard/?tab=cosmetics&checkout=cancel
# ARENA_STRIPE_RETURN_URL=https://YOUR_ARENA_HOST/dashboard/?tab=cosmetics&checkout=return&session_id={CHECKOUT_SESSION_ID}
# Billing Portal returns customers to the same verified-email Dashboard after
# they manage or schedule cancellation of All Access. Retain this during a
# sales pause while any subscription exists.
# ARENA_STRIPE_PORTAL_RETURN_URL=https://YOUR_ARENA_HOST/dashboard/?tab=cosmetics
# Enable only after Stripe Tax is configured for the account and launch regions.
# ARENA_STRIPE_AUTOMATIC_TAX=false
